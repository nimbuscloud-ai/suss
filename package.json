{
  "name": "suss",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Nimbus Cloud AI LLC",
  "workspaces": [
    "packages/ir",
    "packages/extractor",
    "packages/adapter/typescript",
    "packages/framework/ts-rest",
    "packages/framework/react-router",
    "packages/framework/express",
    "packages/cli"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "typescript": "^5.4.0",
    "@vitest/coverage-v8": "^4.0.0",
    "vitest": "^4.0.0",
    "tsup": "^8.0.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "prepare": "husky",
    "badges": "node scripts/generate-coverage-badges.mjs",
    "test:badges": "npm test && npm run badges"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
