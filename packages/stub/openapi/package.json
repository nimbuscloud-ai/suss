{
  "name": "@suss/stub-openapi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Generate suss behavioral summaries from OpenAPI 3.x specifications.",
  "keywords": [
    "suss",
    "behavioral-summary",
    "stub",
    "openapi",
    "swagger",
    "contract"
  ],
  "license": "Apache-2.0",
  "author": "Nimbus Cloud AI LLC",
  "homepage": "https://github.com/nimbuscloud-ai/suss/tree/main/packages/stub/openapi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimbuscloud-ai/suss.git",
    "directory": "packages/stub/openapi"
  },
  "bugs": {
    "url": "https://github.com/nimbuscloud-ai/suss/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@suss/behavioral-ir": "*",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
