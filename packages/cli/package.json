{
  "name": "@suss/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "suss": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@suss/behavioral-ir": "*",
    "@suss/checker": "*",
    "@suss/extractor": "*",
    "@suss/adapter-typescript": "*",
    "@suss/framework-ts-rest": "*",
    "@suss/framework-react-router": "*",
    "@suss/framework-express": "*",
    "@suss/runtime-web": "*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
