{
  "name": "@suss/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Command-line interface for suss — extract, inspect, diff, and check TypeScript behavioral summaries.",
  "keywords": [
    "suss",
    "cli",
    "behavioral-summary",
    "static-analysis",
    "contract-testing",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Nimbus Cloud AI LLC",
  "homepage": "https://github.com/nimbuscloud-ai/suss/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimbuscloud-ai/suss.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/nimbuscloud-ai/suss/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "suss": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@suss/behavioral-ir": "*",
    "@suss/checker": "*",
    "@suss/extractor": "*",
    "@suss/adapter-typescript": "*",
    "@suss/framework-ts-rest": "*",
    "@suss/framework-react-router": "*",
    "@suss/framework-express": "*",
    "@suss/runtime-web": "*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
