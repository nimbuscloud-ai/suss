{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suss.dev/schema/behavioral-summary/v0",
  "title": "Behavioral Summary",
  "description": "A structured, language-agnostic description of a code unit's behavior: under what conditions it produces what outputs. Output of `suss extract`.",
  "type": "array",
  "items": { "$ref": "#/$defs/BehavioralSummary" },

  "$defs": {
    "BehavioralSummary": {
      "type": "object",
      "description": "Complete behavioral description of a single code unit (handler, client, loader, etc.).",
      "required": [
        "kind",
        "location",
        "identity",
        "inputs",
        "transitions",
        "gaps",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/CodeUnitKind" },
        "location": { "$ref": "#/$defs/SourceLocation" },
        "identity": { "$ref": "#/$defs/CodeUnitIdentity" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/Input" }
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Transition" },
          "description": "Every observable execution path through the code unit."
        },
        "gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/Gap" },
          "description": "Cases the code unit doesn't handle — declared-but-not-produced, fall-through, etc."
        },
        "confidence": { "$ref": "#/$defs/ConfidenceInfo" },
        "metadata": {
          "type": "object",
          "description": "Framework-specific data (declared contracts, annotations). Ignored by tools that don't need it."
        }
      }
    },

    "CodeUnitKind": {
      "type": "string",
      "enum": [
        "handler",
        "loader",
        "action",
        "component",
        "hook",
        "middleware",
        "resolver",
        "consumer",
        "client",
        "worker"
      ],
      "description": "What kind of code unit this is. Determines the behavioral model — how inputs arrive and what counts as output."
    },

    "SourceLocation": {
      "type": "object",
      "required": ["file", "range", "exportName"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "File path (relative or absolute, depending on extraction context)."
        },
        "range": {
          "type": "object",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": {
              "type": "integer",
              "description": "Start line number (1-based)."
            },
            "end": {
              "type": "integer",
              "description": "End line number (1-based)."
            }
          }
        },
        "exportName": { "type": ["string", "null"] }
      }
    },

    "BoundaryBinding": {
      "type": "object",
      "required": ["protocol", "framework"],
      "additionalProperties": false,
      "description": "How this code unit binds to an API boundary (HTTP endpoint, message queue, etc.).",
      "properties": {
        "protocol": {
          "type": "string",
          "description": "e.g. \"http\", \"grpc\", \"websocket\"."
        },
        "method": {
          "type": "string",
          "description": "HTTP method (GET, POST, etc.)."
        },
        "path": {
          "type": "string",
          "description": "URL path pattern, e.g. \"/users/:id\"."
        },
        "framework": {
          "type": "string",
          "description": "Framework or runtime that provides the binding."
        },
        "declaredResponses": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Status codes declared in the contract."
        }
      }
    },

    "CodeUnitIdentity": {
      "type": "object",
      "required": ["name", "exportPath", "boundaryBinding"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "exportPath": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            { "type": "null" }
          ]
        },
        "boundaryBinding": {
          "oneOf": [{ "$ref": "#/$defs/BoundaryBinding" }, { "type": "null" }]
        }
      }
    },

    "Derivation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "property"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "propertyAccess" },
            "property": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "method", "args"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "methodCall" },
            "method": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["type", "field"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "destructured" },
            "field": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "awaited" }
          }
        },
        {
          "type": "object",
          "required": ["type", "index"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "indexAccess" },
            "index": { "oneOf": [{ "type": "string" }, { "type": "number" }] }
          }
        }
      ]
    },

    "ValueRef": {
      "description": "A reference to a value in the program. The building block of conditions and outputs.",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "inputRef", "path"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "input" },
            "inputRef": {
              "type": "string",
              "description": "Parameter or input name."
            },
            "path": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Property path from the input root."
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "name", "accessChain"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "dependency" },
            "name": {
              "type": "string",
              "description": "Callee expression text."
            },
            "accessChain": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["type", "from", "derivation"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "derived" },
            "from": { "$ref": "#/$defs/ValueRef" },
            "derivation": { "$ref": "#/$defs/Derivation" }
          }
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "literal" },
            "value": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "null" }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "name"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "state" },
            "name": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "sourceText"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "unresolved" },
            "sourceText": {
              "type": "string",
              "description": "Original source text when resolution failed."
            }
          }
        }
      ]
    },

    "Predicate": {
      "description": "A condition that guards a transition. Structured when the extractor can decompose it, opaque when it can't.",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "subject", "negated"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "nullCheck" },
            "subject": { "$ref": "#/$defs/ValueRef" },
            "negated": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "subject", "negated"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "truthinessCheck" },
            "subject": { "$ref": "#/$defs/ValueRef" },
            "negated": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "left", "op", "right"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "comparison" },
            "left": { "$ref": "#/$defs/ValueRef" },
            "op": {
              "type": "string",
              "enum": ["eq", "neq", "gt", "gte", "lt", "lte"]
            },
            "right": { "$ref": "#/$defs/ValueRef" }
          }
        },
        {
          "type": "object",
          "required": ["type", "subject", "expectedType"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "typeCheck" },
            "subject": { "$ref": "#/$defs/ValueRef" },
            "expectedType": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "subject", "property", "negated"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "propertyExists" },
            "subject": { "$ref": "#/$defs/ValueRef" },
            "property": { "type": "string" },
            "negated": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "op", "operands"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "compound" },
            "op": { "type": "string", "enum": ["and", "or"] },
            "operands": {
              "type": "array",
              "items": { "$ref": "#/$defs/Predicate" }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "operand"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "negation" },
            "operand": { "$ref": "#/$defs/Predicate" }
          }
        },
        {
          "type": "object",
          "required": ["type", "callee", "args"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "call" },
            "callee": { "type": "string" },
            "args": { "type": "array", "items": { "$ref": "#/$defs/ValueRef" } }
          }
        },
        {
          "type": "object",
          "required": ["type", "sourceText", "reason"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "opaque" },
            "sourceText": {
              "type": "string",
              "description": "Original source text preserved when decomposition failed."
            },
            "reason": {
              "type": "string",
              "enum": [
                "complexExpression",
                "externalFunction",
                "dynamicValue",
                "unsupportedSyntax"
              ]
            }
          }
        }
      ]
    },

    "TypeShape": {
      "description": "The shape of a value — what fields it has, what type it is. Used for response bodies, expected inputs, and contract schemas.",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "properties"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "record" },
            "properties": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/TypeShape" },
              "description": "Known fields and their shapes."
            },
            "spreads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["sourceText"],
                "additionalProperties": false,
                "properties": { "sourceText": { "type": "string" } }
              },
              "description": "Spread expressions that contribute additional unknown fields."
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "values"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "dictionary" },
            "values": { "$ref": "#/$defs/TypeShape" }
          }
        },
        {
          "type": "object",
          "required": ["type", "items"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "array" },
            "items": { "$ref": "#/$defs/TypeShape" }
          }
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "literal" },
            "value": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            },
            "raw": {
              "type": "string",
              "description": "Exact source text for numeric literals (precision preservation)."
            }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "text" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "integer" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "number" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "boolean" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "null" } }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "undefined" } }
        },
        {
          "type": "object",
          "required": ["type", "variants"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "union" },
            "variants": {
              "type": "array",
              "items": { "$ref": "#/$defs/TypeShape" }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "name"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "ref" },
            "name": {
              "type": "string",
              "description": "Type name reference (e.g. \"User\", \"string\")."
            }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "unknown" } }
        }
      ]
    },

    "Output": {
      "description": "What the code unit produces at the end of a transition.",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "statusCode", "body", "headers"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "response" },
            "statusCode": {
              "oneOf": [{ "$ref": "#/$defs/ValueRef" }, { "type": "null" }]
            },
            "body": {
              "oneOf": [{ "$ref": "#/$defs/TypeShape" }, { "type": "null" }]
            },
            "headers": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/ValueRef" }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "exceptionType", "message"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "throw" },
            "exceptionType": { "type": ["string", "null"] },
            "message": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object",
          "required": ["type", "component"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "render" },
            "component": { "type": "string" },
            "props": { "type": "object" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "return" },
            "value": {
              "oneOf": [{ "$ref": "#/$defs/TypeShape" }, { "type": "null" }]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "to"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "delegate" },
            "to": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "event"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "emit" },
            "event": { "type": "string" },
            "payload": { "$ref": "#/$defs/TypeShape" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "void" }
          }
        }
      ]
    },

    "Effect": {
      "description": "A side effect observed during a transition (database write, API call, event emission).",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "target", "operation"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "mutation" },
            "target": { "type": "string" },
            "operation": {
              "type": "string",
              "enum": ["create", "update", "delete"]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "callee", "args", "async"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "invocation" },
            "callee": { "type": "string" },
            "args": { "type": "array" },
            "async": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "event"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "emission" },
            "event": { "type": "string" },
            "payload": {}
          }
        },
        {
          "type": "object",
          "required": ["type", "variable"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "stateChange" },
            "variable": { "type": "string" },
            "newValue": {}
          }
        }
      ]
    },

    "Input": {
      "description": "How data enters the code unit.",
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "name", "position", "role", "shape"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "parameter" },
            "name": { "type": "string" },
            "position": { "type": "integer" },
            "role": {
              "type": "string",
              "description": "Semantic role: \"request\", \"response\", \"pathParams\", \"requestBody\", etc."
            },
            "shape": {
              "oneOf": [{ "$ref": "#/$defs/TypeShape" }, { "type": "null" }]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "name", "mechanism", "shape"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "injection" },
            "name": { "type": "string" },
            "mechanism": { "type": "string" },
            "shape": {
              "oneOf": [{ "$ref": "#/$defs/TypeShape" }, { "type": "null" }]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "hook", "destructuredFields"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "hookReturn" },
            "hook": { "type": "string" },
            "destructuredFields": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "context", "accessedFields"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "contextValue" },
            "context": { "type": "string" },
            "accessedFields": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["type", "name"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "closure" },
            "name": { "type": "string" }
          }
        }
      ]
    },

    "Transition": {
      "type": "object",
      "description": "A single execution path: conditions that must hold, the output produced, and side effects observed.",
      "required": [
        "id",
        "conditions",
        "output",
        "effects",
        "location",
        "isDefault"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Content-addressable ID stable across branch reordering."
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Predicate" },
          "description": "Guard conditions — all must hold for this transition to fire."
        },
        "output": { "$ref": "#/$defs/Output" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/Effect" }
        },
        "location": {
          "type": "object",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": { "type": "integer" },
            "end": { "type": "integer" }
          }
        },
        "isDefault": {
          "type": "boolean",
          "description": "True if this transition fires when no other conditions match."
        },
        "confidence": { "$ref": "#/$defs/ConfidenceInfo" },
        "expectedInput": {
          "$ref": "#/$defs/TypeShape",
          "description": "For client code units: the fields the consumer reads from the response body in this branch."
        }
      }
    },

    "Gap": {
      "type": "object",
      "required": ["type", "conditions", "consequence", "description"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "unhandledCase" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Predicate" }
        },
        "consequence": {
          "type": "string",
          "enum": [
            "frameworkDefault",
            "implicitThrow",
            "fallthrough",
            "unknown"
          ]
        },
        "description": { "type": "string" }
      }
    },

    "ConfidenceInfo": {
      "type": "object",
      "required": ["source", "level"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["inferred_static", "inferred_ai", "declared", "stub"]
        },
        "level": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    }
  }
}
